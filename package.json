  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.1",
    "vue": "^3.5.30"
  }
}
