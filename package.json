{
  "name": "cm-frappe-agent-docs",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs",
    "predeploy:syntax": "node -e 'console.log(\"Syntax OK\")'",
    "test:gate": "vitest run --reporter=verbose",
